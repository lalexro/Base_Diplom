MODULE Predmet;

REQUIRE Attestat;

CLASS Predmet 'Предмет';

name 'Предмет' = DATA STRING[20] (Predmet);
rating 'Оценка' = DATA INTEGER (Attestat, Predmet);

countRating 'Кол-во предметов' (Attestat a) = GROUP SUM 1 IF rating(a, Predmet p);
sumRating 'Сумма оценок' (Attestat a) = GROUP SUM NUMERIC[4,2](rating(a, Predmet p));
avgValueAttestat 'Средний балл' (Attestat a) = NUMERIC[4,2](sumRating(a) / countRating(a));

FORM predmets 'Предметы'
    OBJECTS p = Predmet
    PROPERTIES (p) READONLY name
    PROPERTIES (p) NEWSESSION NEW, EDIT, DELETE 

    LIST Predmet OBJECT p
;

FORM predmet 'Предмет'
    OBJECTS p = Predmet PANEL 
    PROPERTIES (p) name

    EDIT Predmet OBJECT p
;

EXTEND FORM attestat
    OBJECTS p = Predmet 
    PROPERTIES (p) READONLY name
    PROPERTIES (a, p) rating
;

EXTEND FORM attestats
    PROPERTIES (a) READONLY avgValueAttestat
;
