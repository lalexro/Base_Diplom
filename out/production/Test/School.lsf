MODULE School;

CLASS School 'Школа';

name 'Название' = DATA STRING[150] (School);
adress 'Адрес' = DATA STRING (School);

FORM schools 'Школы'
    OBJECTS s = School
    PROPERTIES(s) READONLY name, adress
    PROPERTIES(s) NEWSESSION NEW, EDIT, DELETE

    LIST School OBJECT s
;

FORM school 'Школа'
    OBJECTS s = School PANEL
    PROPERTIES(s) name, adress

    EDIT School OBJECT s
;